<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".activity.DetailActivity"
    android:padding="16dp">

    <TextView
        android:id="@+id/detail_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="商品详细信息"
        android:textStyle="bold"
        android:paddingTop="8dp"
        android:textSize="40dp"></TextView>
    <ImageView
        android:paddingTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:id="@+id/detail_image"
        android:src="@mipmap/ic_launcher"
        ></ImageView>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp">
        <TextView
            android:id="@+id/detail_pid1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="id："
            android:textSize="24dp"></TextView>
        <TextView
            android:id="@+id/detail_pid"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="1111"
            android:textStyle="bold"
            android:textSize="24dp"></TextView>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="销售额："
            android:textSize="20dp"
            android:id="@+id/detail_money1"></TextView>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$$$"
            android:textStyle="bold"
            android:textSize="20dp"
            android:id="@+id/detail_money"></TextView>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/detail_pname"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:text="商品名"
                android:textStyle="bold"
                android:textSize="32dp" />
            <TextView
                android:id="@+id/detail_pnum1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="库存:"
                android:textSize="20dp" />
            <TextView
                android:id="@+id/detail_pnum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0000"
                android:textStyle="bold"
                android:textSize="20dp" />
        </LinearLayout>
        <LinearLayout
            android:paddingTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/detail_snum1"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="已售："
                    android:textSize="24dp" />
                <TextView
                    android:id="@+id/detail_snum"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:textStyle="bold"
                    android:text="0000"
                    android:textSize="24dp" />
            </LinearLayout>

                <TextView
                    android:id="@+id/detail_price1"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="售价："
                    android:textSize="24dp" />
                <TextView
                    android:id="@+id/detail_price"
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:textStyle="bold"
                    android:text="$$$"
                    android:textSize="58dp" />

            <Button
                android:id="@+id/detail_button"
                android:layout_width="120dp"
                android:layout_marginLeft="15dp"
                android:layout_height="match_parent"
                android:text="购买"
                android:textSize="28sp"></Button>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>